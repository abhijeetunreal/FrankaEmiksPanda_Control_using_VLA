<mujoco model="franka_vla_workspace">
    <!-- Import the official Franka Panda from the current directory -->
    <include file="panda.xml"/>

    <visual>
        <global offwidth="1920" offheight="1080"/>
    </visual>

    <worldbody>
        <!-- Lighting and Camera -->
        <light pos="0 0 3" dir="0 0 -1" directional="true"/>
        <!-- Camera presets for the web UI -->
        <camera name="main_cam" pos="1.2 0 1.5" xyaxes="0 1 0 -0.5 0 1"/>
        <camera name="front_cam" pos="1.45 0 1.15" xyaxes="0 1 0 -0.35 0 1"/>
        <camera name="top_cam" pos="0.65 0 2.2" xyaxes="1 0 0 0 1 0"/>
        <camera name="side_cam" pos="0.65 -1.3 1.05" xyaxes="1 0 0 0 0 1"/>

        <!-- Tabletop placed right in front of the robot -->
        <geom name="table" type="box" size="0.4 0.6 0.2" pos="0.6 0 0.2" rgba="0.8 0.8 0.8 1" friction="1 0.5 0.0001"/>

        <!-- Colored Objects -->
        <body name="red_box" pos="0.60 0.06 0.45">
            <freejoint/>
            <geom name="red_geom" type="box" size="0.02 0.02 0.02" rgba="1 0 0 1" mass="0.01" friction="1 0.5 0.0001"/>
        </body>
        
        <body name="blue_box" pos="0.60 -0.06 0.45">
            <freejoint/>
            <geom name="blue_geom" type="box" size="0.02 0.02 0.02" rgba="0 0 1 1" mass="0.01" friction="1 0.5 0.0001"/>
        </body>

        <body name="green_box" pos="0.64 0.00 0.45">
            <freejoint/>
            <geom name="green_geom" type="sphere" size="0.02" rgba="0 1 0 1" mass="0.01" friction="1 0.5 0.0001"/>
        </body>
    </worldbody>
</mujoco>