<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

<worldbody>
    <light pos="0 -0.1 0.5" dir="0 0.2 -1" diffuse="0.7 0.7 0.7" specular="0.3 0.3 0.3" directional="true" castshadow="true"/>
    
    <geom name="floor" pos="0 0 0" size="1 1 0.05" type="plane" material="groundplane"/>

    <geom name="table" type="box" size="0.4 0.4 0.2" pos="0.6 0 0.2" rgba="0.2 0.2 0.2 1"/>
    
    <body name="red_cube" pos="0.5 0.1 0.45">
      <freejoint/>
      <geom type="box" size="0.02 0.02 0.02" rgba="1 0.2 0.2 1" mass="0.05" friction="1 0.5 0.0001"/>
    </body>

    <body name="blue_cube" pos="0.5 -0.1 0.45">
      <freejoint/>
      <geom type="box" size="0.02 0.02 0.02" rgba="0.2 0.2 1 1" mass="0.05" friction="1 0.5 0.0001"/>
    </body>

    <body name="target_box" pos="0.7 0 0.41">
      <geom type="box" size="0.08 0.08 0.01" rgba="0.2 0.8 0.2 0.5" contype="0" conaffinity="0"/>
    </body>

    <camera name="vla_cam" pos="1.0 0.0 1.2" xyaxes="0 1 0 -1 0 1" mode="targetbody" target="link0"/>
</worldbody>

</mujoco>
